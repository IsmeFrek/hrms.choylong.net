{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:http": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:VITE_HTTP='1'; vite\"",
    "tunnel:vite": "ngrok http 5173",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "backend": "cd backend && npm run dev",
    "start-backend": "cd backend && npm start",
    "dev-all": "concurrently \"npm run backend\" \"npm run dev\"",
    "dev-mobile": "concurrently -k \"npm run dev:http\" \"npm run tunnel:vite\"",
    "network-setup": "powershell -ExecutionPolicy Bypass -File setup-network.ps1",
    "dev-network": "vite --host 0.0.0.0",
    "backend-network": "cd backend && npm run dev",
    "test-import": "node tools/test-import.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tippyjs/react": "^4.2.6",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "axios": "^1.5.0",
    "date-fns": "^2.30.0",
    "html2pdf.js": "^0.10.3",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.563.0",
    "pdfjs-dist": "^5.4.449",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.45.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.15.0",
    "react-toastify": "^9.1.3",
    "tailwindcss": "^3.3.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.15",
    "concurrently": "^8.2.1",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.4.29",
    "vite": "^7.1.0"
  }
}
