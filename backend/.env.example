# Backend Environment Configuration Example
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kshf_hospital_app

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# See TELEGRAM_SETUP_GUIDE.md for detailed instructions
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456789

# Alternative Telegram bot token name (either TELEGRAM_BOT_TOKEN or TG_BOT_TOKEN works)
# TG_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456789
